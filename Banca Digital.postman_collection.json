{
  "info": {
    "_postman_id": "7048e952-df4b-435d-a251-008c973b8a4b",
    "name": "Banca Digital",
    "description": "Colección completa y corregida para el Sistema Bancario Serverless. Incluye validación de 10 compras para activación de crédito.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "43359596"
  },
  "item": [
    {
      "name": "1. Servicio de Usuario",
      "item": [
        {
          "name": "Registrar Usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Naiker\",\n    \"lastName\": \"Gomez\",\n    \"email\": \"naikergomez0123@gmail.com\",\n    \"password\": \"12345\",\n    \"document\": \"1020304050\"\n}"
            },
            "url": {
              "raw": "{{user_api_url}}/register",
              "host": [
                "{{user_api_url}}"
              ],
              "path": [
                "register"
              ]
            },
            "description": "Crea un usuario y dispara la creación automática de tarjetas de Débito (ACTIVATED) y Crédito (PENDING) vía SQS."
          },
          "response": []
        },
        {
          "name": "Iniciar Sesión (Login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"naikergomez0123@gmail.com\",\n    \"password\": \"12345\"\n}"
            },
            "url": {
              "raw": "{{user_api_url}}/login",
              "host": [
                "{{user_api_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Obtiene el JWT Token y el userId para las siguientes peticiones."
          },
          "response": []
        },
        {
          "name": "Ver Mi Perfil",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{user_api_url}}/profile/{{user_id}}",
              "host": [
                "{{user_api_url}}"
              ],
              "path": [
                "profile",
                "{{user_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Actualizar Dirección/Teléfono",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"address\": \"Avenida Central 123\",\n    \"phone\": \"+573004445566\"\n}"
            },
            "url": {
              "raw": "{{user_api_url}}/profile/{{user_id}}",
              "host": [
                "{{user_api_url}}"
              ],
              "path": [
                "profile",
                "{{user_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Subir Imagen de Perfil (Avatar)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"image\": \"iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==\",\n    \"fileType\": \"image/png\"\n}"
            },
            "url": {
              "raw": "{{user_api_url}}/profile/{{user_id}}/avatar",
              "host": [
                "{{user_api_url}}"
              ],
              "path": [
                "profile",
                "{{user_id}}",
                "avatar"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Servicio de Tarjetas",
      "item": [
        {
          "name": "Activar Tarjeta de Crédito",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"userId\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{card_api_url}}/card/activate",
              "host": [
                "{{card_api_url}}"
              ],
              "path": [
                "card",
                "activate"
              ]
            },
            "description": "REQUERIMIENTO: Solo cambia de PENDING a ACTIVATED si el usuario tiene al menos 10 compras realizadas con su tarjeta de débito."
          },
          "response": []
        },
        {
          "name": "Transacción: Recarga / Depósito (Débito)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"merchant\": \"CAJERO_AUTOMATICO\",\n    \"amount\": 500\n}"
            },
            "url": {
              "raw": "{{card_api_url}}/transactions/save/{{debit_card_id}}",
              "host": [
                "{{card_api_url}}"
              ],
              "path": [
                "transactions",
                "save",
                "{{debit_card_id}}"
              ]
            },
            "description": "Suma saldo a la tarjeta de débito y envía correo de confirmación."
          },
          "response": []
        },
        {
          "name": "Transacción: Compra / Gasto (Débito para activacion)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"merchant\": \"Amazon Store\",\n    \"cardId\": \"{{debit_card_id}}\",\n    \"amount\": 20\n}"
            },
            "url": {
              "raw": "{{card_api_url}}/transactions/purchase",
              "host": [
                "{{card_api_url}}"
              ],
              "path": [
                "transactions",
                "purchase"
              ]
            },
            "description": "Resta saldo de débito. Realiza esto 10 veces para habilitar la activación de la tarjeta de crédito."
          },
          "response": []
        },
        {
          "name": "Pagar Deuda (Crédito)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"merchant\": \"PAGO_ONLINE_PSE\",\n    \"amount\": 200\n}"
            },
            "url": {
              "raw": "{{card_api_url}}/card/paid/{{credit_card_id}}",
              "host": [
                "{{card_api_url}}"
              ],
              "path": [
                "card",
                "paid",
                "{{credit_card_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Reporte de Actividad (Filtro por fecha)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{card_api_url}}/card/{{credit_card_id}}",
              "host": [
                "{{card_api_url}}"
              ],
              "path": [
                "card",
                "{{credit_card_id}}"
              ]
            },
            "description": "Analiza las transacciones en Dynamo dentro del rango de fechas y dispara el correo con el reporte adjunto."
          },
          "response": []
        }
      ]
    }
  ],
